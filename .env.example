# Railway preview profile: use "staging" for the hosted Railway preview contract.
# Bind/base URL behavior: Railway injects PORT; leave LORE_PORT unset unless you intentionally need to override the platform port.
# REQUIRED in staging
LORE_ENV=staging

# Server bind address (default: 127.0.0.1 for local, 0.0.0.0 for staging/Railway)
LORE_HOST=0.0.0.0

# Optional server port override (takes precedence over PORT when set).
# Leave unset/commented on Railway so the platform-injected PORT is used.
# LORE_PORT=

# Cloud runtime fallback port (used when LORE_PORT is unset; Railway injects this)
PORT=

# Canonical base URL — REQUIRED in staging/Railway, used for OAuth callbacks, admin links, and MCP clients
LORE_BASE_URL=https://lore.yourdomain.com

# JWT secret for session signing — REQUIRED in staging/Railway, must be persistent across restarts
LORE_JWT_SECRET=your-very-long-random-secret-here

# Bootstrap admin identity. Lore may default only the email locally, but it NEVER invents a password.
LORE_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
LORE_BOOTSTRAP_ADMIN_PASSWORD=
LORE_BOOTSTRAP_ADMIN_NAME=Bootstrap Admin

# Enable Secure flag on cookies (default: false locally, true in staging)
LORE_COOKIE_SECURE=true

# Data directory for SQLite database — mount this as a Docker volume.
# WAL mode also writes lore.db-wal and lore.db-shm in this same directory.
LORE_DATA_DIR=/data

# PostgreSQL runtime selector. Railway preview requires this to point at the
# Railway-managed PostgreSQL service. Only postgres:// and postgresql:// switch
# the backend; other URLs keep SQLite as the default local backend.
DATABASE_URL=

# Google OAuth (optional — admin login)
LORE_GOOGLE_CLIENT_ID=
LORE_GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — admin login)
LORE_GITHUB_CLIENT_ID=
LORE_GITHUB_CLIENT_SECRET=
