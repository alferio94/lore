# Environment profile: "" or "local" for development, "staging" for staging
# REQUIRED in staging
LORE_ENV=staging

# Server bind address (default: 127.0.0.1 for local, 0.0.0.0 for staging)
LORE_HOST=0.0.0.0

# Preferred server port (takes precedence over PORT when both are set)
LORE_PORT=7437

# Cloud runtime fallback port (used when LORE_PORT is unset)
PORT=

# Canonical base URL — REQUIRED in staging, used for OAuth callbacks and admin links
LORE_BASE_URL=https://lore.yourdomain.com

# JWT secret for session signing — REQUIRED in staging, must be persistent across restarts
LORE_JWT_SECRET=your-very-long-random-secret-here

# Enable Secure flag on cookies (default: false locally, true in staging)
LORE_COOKIE_SECURE=true

# Data directory for SQLite database — mount this as a Docker volume.
# WAL mode also writes lore.db-wal and lore.db-shm in this same directory.
LORE_DATA_DIR=/data

# PostgreSQL runtime selector. Only postgres:// and postgresql:// switch the
# backend; other URLs keep SQLite as the default local backend.
# Search parity, containerized app runtime, and deployment changes are out of scope.
DATABASE_URL=

# Google OAuth (optional — admin login)
LORE_GOOGLE_CLIENT_ID=
LORE_GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — admin login)
LORE_GITHUB_CLIENT_ID=
LORE_GITHUB_CLIENT_SECRET=
